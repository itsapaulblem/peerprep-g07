USER_SERVICE_PORT=3000
QUESTION_SERVICE_PORT=3001
MATCHING_SERVICE_PORT=3002
GATEWAY_PORT=3004
FRONTEND_PORT=3038
COLLAB_SERVICE_PORT=3003
COLLAB_YJS_WS_PORT=8081

USER_DB_NAME=userdb
USER_DB_USER=postgres
USER_DB_PASSWORD=postgres

QUESTION_DB_NAME=questiondb
QUESTION_DB_USER=postgres
QUESTION_DB_PASSWORD=postgres

DEFAULT_DB_PORT=5432

USER_SERVICE_URL=http://user-service:${USER_SERVICE_PORT}
QUESTION_SERVICE_URL=http://question-service:${QUESTION_SERVICE_PORT}
MATCHING_SERVICE_URL=http://matching-service:${MATCHING_SERVICE_PORT}
COLLAB_SERVICE_URL=http://collaboration-service:${COLLAB_SERVICE_PORT}
COLLAB_WS_URL=ws://collaboration-service:${COLLAB_YJS_WS_PORT}
COLLAB_YJS_WS_URL=/ws/yjs
COLLAB_CHAT_WS_URL=/ws/chat
GATEWAY_URL=/api
FRONTEND_URL=http://localhost:${FRONTEND_PORT}

REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET=RandomKeyForJWT
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_USERNAME=

# AWS S3 — question service
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=peerprep-question-image

LEETCODE_API_URL=http://leetcode-api:3000
LEETCODE_SYNC_CRON=* * * * *      # testing: every minute; change to 0 * * * * for hourly
LEETCODE_FETCH_LIMIT=2
LEETCODE_REQUEST_DELAY_MS=5000
LEETCODE_MAX_RETRIES=3
LEETCODE_RETRY_DELAY_MS=10000
LEETCODE_RUN_ON_START=false
LEETCODE_BATCH_SIZE=5
LEETCODE_RATE_LIMIT_DELAY_MS=300000
